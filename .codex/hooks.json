{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/destructive-preflight.js\"",
            "commandWindows": "node -e \"const{execFileSync}=require('node:child_process');const{join}=require('node:path');require(join(execFileSync('git',['rev-parse','--show-toplevel'],{encoding:'utf8'}).trim(),'.codex','hooks','destructive-preflight.js')).main()\"",
            "timeout": 30,
            "statusMessage": "Checking destructive-action boundaries"
          }
        ]
      }
    ]
  }
}
