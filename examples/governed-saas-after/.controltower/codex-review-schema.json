{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "modelVerdict",
    "summary",
    "claimAudits",
    "nextSafeAction"
  ],
  "properties": {
    "modelVerdict": {
      "type": "string",
      "enum": [
        "PASS",
        "WARN",
        "FAIL"
      ]
    },
    "summary": {
      "type": "string"
    },
    "claimAudits": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "modelAssessment",
          "rationale",
          "citedEvidencePaths",
          "counterEvidence",
          "missingEvidence",
          "recommendedNextAction"
        ],
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "TEST_EXECUTION",
              "CI_EXECUTION",
              "REVIEW_GATE",
              "EVIDENCE_BOUNDARY",
              "EXTERNAL_GATES",
              "MISSION_CHANGE_TEST_ALIGNMENT"
            ]
          },
          "modelAssessment": {
            "type": "string",
            "enum": [
              "SUPPORTS",
              "CONTRADICTS",
              "INSUFFICIENT"
            ]
          },
          "rationale": {
            "type": "string"
          },
          "citedEvidencePaths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "counterEvidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missingEvidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommendedNextAction": {
            "type": "string"
          }
        }
      }
    },
    "nextSafeAction": {
      "type": "string"
    }
  }
}
